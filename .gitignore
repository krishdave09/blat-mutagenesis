# --- Data: raw is user-supplied, interim/processed are regenerated ---
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# --- Models & large weights (regenerated by the pipeline) ---
models/*
!models/.gitkeep
*.joblib
*.pkl
*.pt
*.ckpt

# --- Results: keep tables/figures out of git; they are build outputs ---
results/figures/*
!results/figures/.gitkeep
results/tables/*
!results/tables/.gitkeep

# --- Python / Jupyter ---
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
env/
*.egg-info/

# --- OS / editor cruft ---
.DS_Store
.idea/
.vscode/
_to_delete/
